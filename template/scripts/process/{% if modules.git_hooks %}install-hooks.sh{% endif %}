#!/usr/bin/env bash
# Installs dev-process git hooks into .git/hooks (host-local, not versioned;
# THIS script is the source of truth). Brownfield-safe: a pre-existing hook not
# managed by dev-process is left untouched. Idempotent — re-run any time.
set -e
MARKER="# dev-process-managed-hook"
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || {
  echo "✗ not a git repository — run this from inside your repo." >&2
  exit 1
}
cd "$REPO_ROOT"  # --git-path returns a CWD-relative path; anchor it at the root

# A configured core.hooksPath (often global: husky, ~/.githooks) redirects
# every hook lookup. Writing there would install dev-process hooks machine-wide
# and the foreign-hook detection below would check the wrong directory.
HOOKS_PATH_CFG="$(git config --get core.hooksPath || true)"
if [ -n "$HOOKS_PATH_CFG" ]; then
  echo "x core.hooksPath is configured ('$HOOKS_PATH_CFG') — refusing to install." >&2
  echo "  dev-process hooks target .git/hooks; integrate them into your hook manager" >&2
  echo "  manually (this script is the source of truth for their contents)." >&2
  exit 1
fi
HOOK_DIR="$(git rev-parse --git-path hooks)"
mkdir -p "$HOOK_DIR"

# 0 = safe to (over)write our hook; 1 = a foreign hook is present, skip it.
can_write() {
  target="$HOOK_DIR/$1"
  if [ -e "$target" ] && ! grep -q "$MARKER" "$target" 2>/dev/null; then
    echo "⚠ $1 exists and is not dev-process-managed — leaving it untouched." >&2
    echo "  Merge the dev-process $1 manually if you want its checks." >&2
    return 1
  fi
  return 0
}

if can_write pre-commit; then
cat > "$HOOK_DIR/pre-commit" << 'EOF'
#!/usr/bin/env bash
# dev-process-managed-hook
# Blocks direct commits to main/master. Feature branch + ff-only merge to main.
# Automation escape: ALLOW_MAIN_COMMIT=1.
# symbolic-ref (not rev-parse --abbrev-ref): works on an unborn branch too,
# so the very first commit on main is also blocked.
branch="$(git symbolic-ref --short HEAD 2>/dev/null)"
if { [ "$branch" = "main" ] || [ "$branch" = "master" ]; } && [ "${ALLOW_MAIN_COMMIT:-0}" != "1" ]; then
  echo "✗ Direct commit to '$branch' blocked. Use a feature branch; ff-only merge to main." >&2
  echo "  Automation: ALLOW_MAIN_COMMIT=1 git commit ..." >&2
  exit 1
fi
exit 0
EOF
chmod +x "$HOOK_DIR/pre-commit"
echo "✓ installed pre-commit"
fi

if can_write pre-push; then
cat > "$HOOK_DIR/pre-push" << 'EOF'
#!/usr/bin/env bash
# dev-process-managed-hook
# Gates the COMMITS BEING PUSHED, not the working tree: for each pushed ref the
# hook checks the pushed tip out into a throwaway detached worktree and runs the
# manifest-aware gate runner there. This isolates the check from local
# uncommitted state (which could otherwise mask OR cause failures) and is
# parallel-safe (no stash, no HEAD move). With no CI configured, this
# pushed-commit gate is the last automated check before the remote.
# Bypass: git push --no-verify, or SKIP_PUSH_GATE=1.
[ "${SKIP_PUSH_GATE:-0}" = "1" ] && { echo "⚠ pre-push gate skipped (SKIP_PUSH_GATE=1)." >&2; exit 0; }
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
cd "$REPO_ROOT" || exit 0
# Drop Git's hook-local env (GIT_DIR/GIT_WORK_TREE/GIT_INDEX_FILE/…) so every git
# command below — and any git a gate runs — resolves the throwaway worktree it
# is standing in, not the pushing worktree that invoked the hook.
unset $(git rev-parse --local-env-vars 2>/dev/null)
# Read the whole ref stream up front: once consumed, no child command (e.g. a
# post-checkout hook fired by `git worktree add`) can drain the remaining refs.
refs="$(cat)"
ZERO="0000000000000000000000000000000000000000"
gate_status=0
while read -r _lref lsha _rref _rsha; do
  [ -z "$lsha" ] && continue
  [ "$lsha" = "$ZERO" ] && continue   # branch deletion — nothing to gate
  wt="$(mktemp -d "${TMPDIR:-/tmp}/devproc-prepush.XXXXXX")" || continue
  if git worktree add --quiet --detach "$wt" "$lsha" </dev/null 2>/dev/null; then
    if [ -f "$wt/scripts/process/gate_runner.py" ]; then
      ( cd "$wt" && python3 scripts/process/gate_runner.py </dev/null ) || gate_status=1
    fi
    git worktree remove --force "$wt" </dev/null 2>/dev/null
  else
    echo "⚠ pre-push: could not materialize $lsha for gating; not blocking." >&2
  fi
  rm -rf "$wt" 2>/dev/null
done <<< "$refs"
exit $gate_status
EOF
chmod +x "$HOOK_DIR/pre-push"
echo "✓ installed pre-push"
fi

if can_write post-commit; then
cat > "$HOOK_DIR/post-commit" << 'EOF'
#!/usr/bin/env bash
# dev-process-managed-hook
# Warn-only drift feedback after each commit (never blocks).
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
cd "$REPO_ROOT" || exit 0
[ -f scripts/process/gate_runner.py ] || exit 0
python3 scripts/process/gate_runner.py --warn || true
EOF
chmod +x "$HOOK_DIR/post-commit"
echo "✓ installed post-commit"
fi

echo "Done. Bypass: ALLOW_MAIN_COMMIT=1 (pre-commit); SKIP_PUSH_GATE=1 or --no-verify (pre-push)."
