#!/usr/bin/env python3
"""github-master gate: when GitHub is the source of truth, keep the local
registry an honest mirror of it — hermetically.

The truth lives in GitHub (issues, sub-issues, board). The `gh_sync.py` tool
pulls that truth into a committed snapshot (`.process-work/github-snapshot.json`)
over the network. THIS gate never touches the network: it checks, offline and
deterministically, that the committed registry agrees with the committed
snapshot, and that the master invariants hold. Freshness of the snapshot vs live
GitHub is the sync tool's job, not a gate's.

With this module off, nothing here runs and the registry stays the source of
truth (the portable default). Stdlib only.
"""
from __future__ import annotations

import json
import sys
from pathlib import Path

REGISTRY_DIR = "docs/process/feature-registry"
SNAPSHOT = ".process-work/github-snapshot.json"

# process status -> the GitHub issue state it must map to
STATUS_STATE = {"proposed": "open", "in-progress": "open",
                "done": "closed", "deprecated": None}  # deprecated: either
# board column (case-insensitive) -> the story status it implies
BOARD_STATUS = {"backlog": "proposed", "ready": "proposed",
                "in-progress": "in-progress", "in progress": "in-progress",
                "review": "in-progress", "done": "done"}
ENTRY_KEYS = {"number", "story", "title", "state", "status",
              "blocked_by", "parent", "board_status", "dor"}


def _stories(root: Path) -> dict:
    """Registry stories by id: {id: {title, status, blocked_by, has_issue}}."""
    reg = root / REGISTRY_DIR
    out: dict = {}
    if not reg.is_dir():
        return out
    for p in sorted(reg.glob("*.json")):
        if p.name.endswith(".example.json"):
            continue
        try:
            d = json.loads(p.read_text(encoding="utf-8"))
        except (json.JSONDecodeError, UnicodeDecodeError):
            continue  # the feature-registry gate owns JSON validity
        if not isinstance(d, dict) or not isinstance(d.get("id"), str):
            continue
        out[d["id"]] = {
            "title": d.get("title"),
            "status": d.get("status"),
            "blocked_by": d.get("blocked_by") or [],
            "parent": d.get("parent"),
            "has_issue": bool(d.get("issue")),
            "rel": f"{REGISTRY_DIR}/{p.name}",
        }
    return out


def _load_snapshot(root: Path) -> tuple[dict | None, list[str], object]:
    """(entries_by_story, hard_errors, generated_at). entries_by_story is None
    when the snapshot is absent (a soft, pre-sync state the caller reports)."""
    f = root / SNAPSHOT
    if not f.is_file():
        return None, [], None
    try:
        raw = f.read_text(encoding="utf-8")
    except UnicodeDecodeError:
        return {}, [f"{SNAPSHOT}: not valid UTF-8"], None
    try:
        data = json.loads(raw)
    except json.JSONDecodeError as exc:
        return {}, [f"{SNAPSHOT}: invalid JSON: {exc}"], None
    if not isinstance(data, dict) or not isinstance(data.get("issues"), list):
        return {}, [f"{SNAPSHOT}: must be an object with an 'issues' list"], None
    generated_at = data.get("generated_at")
    top_extra = set(data) - {"generated_by", "generated_at", "issues"}
    hard: list[str] = []
    if top_extra:
        hard.append(f"{SNAPSHOT}: unknown top-level key(s): {sorted(top_extra)}")
    by_story: dict = {}
    for i, e in enumerate(data["issues"]):
        if not isinstance(e, dict):
            hard.append(f"{SNAPSHOT}: issues[{i}] must be an object")
            continue
        extra = set(e) - ENTRY_KEYS
        if extra:
            hard.append(f"{SNAPSHOT}: issues[{i}] has unknown key(s): {sorted(extra)}")
        sid = e.get("story")
        if not isinstance(sid, str) or not sid:
            hard.append(f"{SNAPSHOT}: issues[{i}] missing 'story'")
            continue
        if sid in by_story:  # a duplicate would silently mask a divergent entry
            hard.append(f"{SNAPSHOT}: duplicate entry for {sid}")
            continue
        if e.get("state") not in ("open", "closed"):
            hard.append(f"{SNAPSHOT}: {sid} 'state' must be 'open' or 'closed'")
        # type-guard the slots the drift loop consumes — a malformed committed
        # snapshot must fail clean, never traceback
        for key in ("title", "status"):
            if e.get(key) is not None and not isinstance(e[key], str):
                hard.append(f"{SNAPSHOT}: {sid} {key!r} must be a string or null")
        bl = e.get("blocked_by")
        if bl is not None:
            if not isinstance(bl, list):
                hard.append(f"{SNAPSHOT}: {sid} 'blocked_by' must be a list or null")
            elif not all(isinstance(x, str) for x in bl):
                # the drift loop sorts this list — a non-string element would
                # traceback on comparison; fail clean instead (audit)
                hard.append(f"{SNAPSHOT}: {sid} 'blocked_by' has a non-string element")
                e = {**e, "blocked_by": None}  # neutralize before the drift loop
        dor = e.get("dor")
        if dor is not None and not (
                isinstance(dor, dict)
                and set(dor) == {"typed", "ears", "deviation"}
                and all(isinstance(dor[k], bool) for k in dor)):
            hard.append(f"{SNAPSHOT}: {sid} 'dor' must be null or an object with "
                        f"boolean typed/ears/deviation")
            e = {**e, "dor": None}  # neutralize before the DoR check
        by_story[sid] = e
    return by_story, hard, generated_at


def _invariant_hard(stories: dict, snap: dict) -> list[str]:
    """Every *live* story traces to an issue and a snapshot entry. Deprecated
    stories are retired — exempt from both."""
    hard: list[str] = []
    for sid, s in sorted(stories.items()):
        if s["status"] == "deprecated":
            continue
        if not s["has_issue"]:
            hard.append(f"{s['rel']}: {sid} has no 'issue' — github-master mode "
                        f"requires every live story to trace to an issue")
        if sid not in snap:
            hard.append(f"{s['rel']}: {sid} has no snapshot entry — mirror is stale, "
                        f"re-run gh_sync.py")
    return hard


def _completeness_hard(stories: dict, snap: dict) -> list[str]:
    """Every pulled issue has a materialized story (mirror complete both ways)."""
    return [f"{SNAPSHOT}: {sid} pulled from GitHub but no registry story "
            f"exists — materialize it"
            for sid in sorted(snap) if sid not in stories]


def _drift_hard(stories: dict, snap: dict) -> list[str]:
    """On the fields GitHub owns, the registry may not diverge from the snapshot.
    `null` slots are skipped (not yet mastered here)."""
    hard: list[str] = []
    for sid in sorted(set(stories) & set(snap)):
        s, e = stories[sid], snap[sid]
        if e.get("title") is not None and s["title"] != e["title"]:
            hard.append(f"{s['rel']}: {sid} title drifts from GitHub "
                        f"({s['title']!r} vs {e['title']!r}) — re-sync")
        # process status is GitHub-mastered (label/board) — compare it directly,
        # not only its coarse open/closed projection (proposed vs in-progress
        # both map to 'open' and would otherwise slip)
        if e.get("status") is not None and s["status"] != e["status"]:
            hard.append(f"{s['rel']}: {sid} status drifts from GitHub "
                        f"({s['status']!r} vs {e['status']!r}) — re-sync")
        want_state = STATUS_STATE.get(s["status"])
        if want_state is not None and e.get("state") != want_state:
            hard.append(f"{s['rel']}: {sid} status {s['status']!r} implies "
                        f"issue {want_state}, but snapshot has {e.get('state')!r}")
        if e.get("parent") is not None and s["parent"] != e["parent"]:
            hard.append(f"{s['rel']}: {sid} parent drifts from GitHub "
                        f"({s['parent']!r} vs {e['parent']!r}) — re-sync sub-issue link")
        # board column consistency (deprecated stories are off the board, exempt)
        board = e.get("board_status")
        if board is not None and s["status"] != "deprecated":
            col = board.lower() if isinstance(board, str) else None
            if col not in BOARD_STATUS:
                hard.append(f"{s['rel']}: {sid} board column {board!r} is not a known "
                            f"column ({', '.join(sorted(set(BOARD_STATUS)))})")
            elif s["status"] != BOARD_STATUS[col]:
                hard.append(f"{s['rel']}: {sid} board column {board!r} implies status "
                            f"{BOARD_STATUS[col]!r}, but the story is {s['status']!r}")
        if isinstance(e.get("blocked_by"), list) and \
                sorted(s["blocked_by"]) != sorted(e["blocked_by"]):
            hard.append(f"{s['rel']}: {sid} blocked_by drifts from GitHub "
                        f"({sorted(s['blocked_by'])} vs {sorted(e['blocked_by'])})")
    return hard


def _dor_checks(stories: dict, snap: dict) -> tuple[list[str], list[str]]:
    """Definition of Ready, enforced at rest: an *in-progress* story (work has
    started) must link an issue that is Ready — typed (R1) and EARS-gradeable
    (R2, epics exempt at sync time) — or carry a recorded `## Deviations` note
    (the DoR's named escape). Facts come from the snapshot's `dor` slot, which
    gh_sync derives from the live issue; a snapshot predating that slot degrades
    to a note (re-sync), never a fake fail. Proposed stories are not yet
    started and `done` is the review gate's business — both out of scope."""
    hard: list[str] = []
    stale: list[str] = []
    for sid in sorted(set(stories) & set(snap)):
        s = stories[sid]
        if s["status"] != "in-progress":
            continue
        dor = snap[sid].get("dor")
        if dor is None:
            stale.append(sid)
            continue
        if dor["deviation"]:
            continue  # recorded, justified deviation — the named escape
        missing = [name for flag, name in ((dor["typed"], "a type: label (R1)"),
                                           (dor["ears"], "EARS acceptance (R2)"))
                   if not flag]
        if missing:
            hard.append(f"{s['rel']}: {sid} is in-progress but its issue is not "
                        f"Ready — missing {' and '.join(missing)}; make it ready "
                        f"or record a '## Deviations' note on the issue, then "
                        f"re-run gh_sync.py (definition-of-ready-and-done.md)")
    soft = ([f"{len(stale)} in-progress story(ies) have a snapshot entry without "
             f"DoR facts ({', '.join(stale)}) — snapshot predates the dor slot; "
             f"re-run gh_sync.py to enforce the Definition of Ready"]
            if stale else [])
    return hard, soft


def check(root: Path) -> tuple[list[str], list[str]]:
    hard: list[str] = []
    snap, snap_hard, generated_at = _load_snapshot(root)
    hard += snap_hard
    if snap is None:
        return hard, ["no github-snapshot.json yet — run gh_sync.py (expected pre-sync)"]

    # Freshness is NOT gated: this gate is deterministic over the *committed*
    # snapshot, so a snapshot that lags GitHub still passes green. Surface that
    # every run — the caveat belongs where the reader sees the result, not only
    # in the docs. The gate cannot check freshness without a clock/network.
    stamp = generated_at if generated_at is not None else "unknown (no generated_at)"
    soft = [f"freshness is not gated — snapshot generated_at={stamp!r}; "
            f"re-run gh_sync.py if GitHub changed since (a stale mirror passes)"]

    stories = _stories(root)
    if not stories:
        # an empty mirror is a no-op, not proof of consistency — say so instead
        # of a bare green (this module depends on populated feature-registry stories)
        soft.append(f"no stories under {REGISTRY_DIR}/ — nothing is mirrored, "
                    f"so there is nothing to verify (populate the registry, "
                    f"then re-sync)")
    hard += _invariant_hard(stories, snap)
    hard += _completeness_hard(stories, snap)
    hard += _drift_hard(stories, snap)
    dor_hard, dor_soft = _dor_checks(stories, snap)
    hard += dor_hard
    soft += dor_soft
    return hard, soft


def main() -> int:
    root = Path(sys.argv[1] if len(sys.argv) > 1 else ".").resolve()
    if not root.is_dir():
        print(f"github-master: FAILED:\n  - root {root} is not a directory")
        return 1
    hard, soft = check(root)
    for note in soft:
        print(f"github-master: note: {note}")
    if hard:
        print("github-master: FAILED:")
        for h in sorted(set(hard)):
            print(f"  - {h}")
        return 1
    print("github-master: OK")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
