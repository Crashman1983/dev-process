#!/usr/bin/env python3
"""doc-drift-gate: verify that repo-relative path references in docs/process/
and the harness adapters (CLAUDE.md/AGENTS.md/instructions plus the
.claude/commands and .github/prompts command files) actually resolve.
Portable, language-agnostic.

Only references that contain a slash (repo-relative paths) are checked; bare
filenames and obvious placeholders (<...>, YYYY, NNNN, *) are ignored to avoid
false positives on illustrative examples."""
from __future__ import annotations

import re
import sys
from pathlib import Path

LINK = re.compile(r"\[[^\]]+\]\(([^)]+)\)")          # markdown links
BACKTICK = re.compile(r"`([^`]+\.[a-z]{1,5})`")      # `path/to/file.ext`
PLACEHOLDER = re.compile(r"[<>*]|YYYY|NNNN")         # illustrative, not literal
SCAN_DIRS = ["docs/process", ".claude/commands", ".github/prompts"]
SCAN_FILES = ["CLAUDE.md", "AGENTS.md", ".github/copilot-instructions.md", "ARCHITECTURE.md", "ARCHITECTURE-OVERVIEW.md", "PRODUCT.md"]


def _candidates(text: str):
    for m in LINK.finditer(text):
        yield m.group(1)
    for m in BACKTICK.finditer(text):
        yield m.group(1)


def _is_local_path(ref: str) -> bool:
    if ref.startswith(("http://", "https://", "#", "mailto:")):
        return False
    if " " in ref:          # a command or prose fragment, not a path
        return False
    if PLACEHOLDER.search(ref):
        return False
    if ".process-work/" in ref:  # runtime working memory, created at runtime, never shipped
        return False
    return "/" in ref


def find_drift(root: Path) -> list[str]:
    targets: list[Path] = []
    for d in SCAN_DIRS:
        targets += (root / d).rglob("*.md")
    for f in SCAN_FILES:
        if (root / f).is_file():
            targets.append(root / f)
    problems: list[str] = []
    for doc in targets:
        try:
            text = doc.read_text(encoding="utf-8")
        except UnicodeDecodeError as exc:
            problems.append(f"{doc.relative_to(root)} -> not valid UTF-8: {exc}")
            continue
        for ref in _candidates(text):
            ref_clean = ref.split("#", 1)[0].strip()
            if not _is_local_path(ref_clean):
                continue
            # standard markdown: ./ and ../ are document-relative; bare paths
            # keep the repo-root convention
            base = doc.parent if ref_clean.startswith(("./", "../")) else root
            if not (base / ref_clean).resolve().exists():
                problems.append(f"{doc.relative_to(root)} -> missing '{ref_clean}'")
    return problems


def main() -> int:
    root = Path(sys.argv[1] if len(sys.argv) > 1 else ".").resolve()
    problems = find_drift(root)
    if problems:
        print("doc-drift-gate: broken references:")
        for p in problems:
            print(f"  - {p}")
        return 1
    print("doc-drift-gate: OK")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
