#!/usr/bin/env python3
# /// script
# requires-python = ">=3.11"
# dependencies = ["pyyaml>=6,<7"]
# ///
"""Manifest-aware gate runner. Reads .copier-answers.yml and runs only the
gates whose module is active. Language-agnostic; each gate is a subprocess.

The manifest is load-bearing: a missing or malformed .copier-answers.yml is a
hard failure, never an empty gate list — otherwise enforcement can disappear
silently while reporting green."""
from __future__ import annotations

import os
import subprocess
import sys
from pathlib import Path

GATE_TIMEOUT_S = 600  # a wedged gate (e.g. pathological regex) must fail, not hang CI

try:
    import yaml
except ImportError:
    print("gate-runner: PyYAML is required — pip install 'PyYAML>=6'", file=sys.stderr)
    raise SystemExit(1)

# gate-name -> (module answer key, command relative to repo root).
# A module key of None marks a *core* gate: it ships in core and always runs,
# regardless of the manifest. Core gates guard artifacts that are themselves
# core (e.g. docs/process/adr/), so their enforcement must not hinge on an
# optional module being enabled.
GATES = {
    "kernel": (None, [sys.executable, "scripts/process/check_kernel.py", "."]),
    "decision-records": (None, [sys.executable, "scripts/process/check_decisions.py", "."]),
    "review": (None, [sys.executable, "scripts/process/check_review.py", "."]),
    "product-frame": (None, [sys.executable, "scripts/process/check_product_frame.py", "."]),
    "doc-drift-gate": ("doc_drift_gate", [sys.executable, "scripts/process/check_doc_drift.py", "."]),
    "arch-onboarding": ("arch_onboarding", [sys.executable, "scripts/process/check_architecture.py", "."]),
    "feature-registry": ("feature_registry", [sys.executable, "scripts/process/check_feature_registry.py", "."]),
    "github-issues": ("github_issues", [sys.executable, "scripts/process/check_issues.py", "."]),
    "contracts-drift": ("contracts_drift", [sys.executable, "scripts/process/check_contracts.py", "."]),
    "contract-first": ("contract_first", [sys.executable, "scripts/process/check_capability_contracts.py", "."]),
    "parity": ("parity", [sys.executable, "scripts/process/check_parity.py", "."]),
    "security-floor": ("security_floor", [sys.executable, "scripts/process/check_security_floor.py", "."]),
    "sbom": ("sbom", [sys.executable, "scripts/process/check_sbom.py", "."]),
    "telemetry": ("telemetry", [sys.executable, "scripts/process/check_telemetry.py", "."]),
    "arch-docs": ("arch_docs", [sys.executable, "scripts/process/check_arch_docs.py", "."]),
    "github-master": ("github_master", [sys.executable, "scripts/process/check_github_master.py", "."]),
}
KNOWN_MODULES = {key for key, _command in GATES.values() if key is not None} | {"git_hooks"}
KNOWN_HARNESSES = {"claude", "copilot", "agents_md"}


def _validate_boolean_mapping(
    answers: dict, field: str, known_keys: set[str], label: str, *, required: bool = False
) -> dict:
    if required and field not in answers:
        print(f"gate-runner: manifest has no '{field}' mapping", file=sys.stderr)
        raise SystemExit(1)
    values = answers.get(field, {})
    if not isinstance(values, dict):
        print(f"gate-runner: '{field}' must be a mapping", file=sys.stderr)
        raise SystemExit(1)
    unknown = sorted(set(values) - known_keys)
    if unknown:
        print(f"gate-runner: unknown {label} key(s): {', '.join(unknown)}", file=sys.stderr)
        raise SystemExit(1)
    invalid = sorted(key for key, value in values.items() if not isinstance(value, bool))
    if invalid:
        print(
            f"gate-runner: {label} values must be booleans: {', '.join(invalid)}",
            file=sys.stderr,
        )
        raise SystemExit(1)
    return values


def load_modules(root: Path) -> dict:
    """The manifest's modules mapping; raises SystemExit with a diagnostic
    on anything that would otherwise silently disable enforcement."""
    f = root / ".copier-answers.yml"
    try:
        answers = yaml.safe_load(f.read_text(encoding="utf-8"))
    except (yaml.YAMLError, UnicodeDecodeError) as exc:
        print(f"gate-runner: unparseable {f}: {exc}", file=sys.stderr)
        raise SystemExit(1)
    if not isinstance(answers, dict):
        print(
            f"gate-runner: {f} must contain a top-level mapping — manifest corrupt",
            file=sys.stderr,
        )
        raise SystemExit(1)
    mods = _validate_boolean_mapping(
        answers, "modules", KNOWN_MODULES, "module", required=True
    )
    _validate_boolean_mapping(answers, "harnesses", KNOWN_HARNESSES, "harness")
    return mods


def main() -> int:
    root = Path(__file__).resolve().parents[2]
    if not (root / ".copier-answers.yml").is_file():
        print(
            f"gate-runner: no .copier-answers.yml found at rendered repo root {root}; "
            "enforcement cannot be verified",
            file=sys.stderr,
        )
        return 1
    mods = load_modules(root)
    # core gates (key is None) always run; module gates run when their key is on
    active = [name for name, (key, _cmd) in GATES.items() if key is None or mods.get(key)]
    if "--list" in sys.argv:
        for g in active:
            print(g)
        return 0
    warn = "--warn" in sys.argv
    failed = []
    # don't litter the repo with __pycache__ from the gates' sibling imports
    env = {**os.environ, "PYTHONDONTWRITEBYTECODE": "1"}
    for name in active:
        _key, cmd = GATES[name]
        script = root / cmd[1]
        if not script.is_file():
            # a module enabled in the manifest whose gate script is missing is
            # almost always a hand-edited .copier-answers.yml (copier then never
            # renders the module) — name the cause, not just the missing file
            print(f"gate-runner: {name} is enabled in the manifest but "
                  f"{cmd[1]} is missing — if .copier-answers.yml was edited by "
                  f"hand, revert it and enable the module via `copier update "
                  f"--data` instead (see BOOTSTRAP 'Later')", file=sys.stderr)
            failed.append(name)
            continue
        print(f"== running {name} ==")
        try:
            rc = subprocess.run(cmd, cwd=root, env=env, timeout=GATE_TIMEOUT_S).returncode
        except subprocess.TimeoutExpired:
            print(f"gate-runner: {name} exceeded {GATE_TIMEOUT_S}s and was killed "
                  f"— a hanging gate is a failure, not a wait", file=sys.stderr)
            rc = 1
        if rc != 0:
            failed.append(name)
    if failed:
        if warn:
            print(f"gate warnings (not blocking): {', '.join(failed)}")
            return 0
        print(f"FAILED gates: {', '.join(failed)}")
        return 1
    print(f"all {len(active)} active gate(s) passed")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
