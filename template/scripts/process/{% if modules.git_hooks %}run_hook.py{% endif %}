#!/usr/bin/env python3
# /// script
# requires-python = ">=3.11"
# ///
"""Portable implementations of the dev-process Git hook behaviors."""
from __future__ import annotations

import os
import subprocess
import sys
import tempfile
from pathlib import Path

ZERO_SHA = "0" * 40


def _run(args: list[str], root: Path, **kwargs) -> subprocess.CompletedProcess:
    return subprocess.run(args, cwd=root, check=False, **kwargs)


def _root() -> Path:
    result = subprocess.run(
        ["git", "rev-parse", "--show-toplevel"], capture_output=True, text=True, check=False
    )
    if result.returncode:
        raise RuntimeError(result.stderr.strip() or "not a Git repository")
    return Path(result.stdout.strip()).resolve()


def _clean_git_env(root: Path) -> dict[str, str]:
    env = dict(os.environ)
    result = _run(
        ["git", "rev-parse", "--local-env-vars"], root, capture_output=True, text=True
    )
    if result.returncode == 0:
        for key in result.stdout.splitlines():
            env.pop(key, None)
    env["PYTHONDONTWRITEBYTECODE"] = "1"
    return env


def pre_commit(root: Path) -> int:
    if os.environ.get("ALLOW_MAIN_COMMIT") == "1":
        return 0
    result = _run(
        ["git", "symbolic-ref", "--short", "HEAD"], root, capture_output=True, text=True
    )
    branch = result.stdout.strip()
    if branch in {"main", "master"}:
        print(f"Direct commit to '{branch}' blocked. Use a feature branch.", file=sys.stderr)
        return 1
    return 0


def _gate_commit(root: Path, sha: str, env: dict[str, str]) -> int:
    with tempfile.TemporaryDirectory(prefix="devproc-prepush-") as directory:
        worktree = Path(directory)
        added = _run(
            ["git", "worktree", "add", "--quiet", "--detach", str(worktree), sha],
            root,
            env=env,
            stdin=subprocess.DEVNULL,
            capture_output=True,
            text=True,
        )
        if added.returncode:
            print(f"warning: pre-push could not materialize {sha}; not blocking.", file=sys.stderr)
            return 0
        try:
            runner = worktree / "scripts/process/gate_runner.py"
            if not runner.is_file():
                return 0
            return _run(
                ["uv", "run", "scripts/process/gate_runner.py"],
                worktree,
                env=env,
                stdin=subprocess.DEVNULL,
            ).returncode
        finally:
            _run(
                ["git", "worktree", "remove", "--force", str(worktree)],
                root,
                env=env,
                stdin=subprocess.DEVNULL,
                capture_output=True,
            )


def pre_push(root: Path) -> int:
    if os.environ.get("SKIP_PUSH_GATE") == "1":
        print("pre-push gate skipped (SKIP_PUSH_GATE=1).", file=sys.stderr)
        return 0
    env = _clean_git_env(root)
    status = 0
    for line in sys.stdin:
        fields = line.split()
        if len(fields) != 4:
            continue
        sha = fields[1]
        if sha != ZERO_SHA and _gate_commit(root, sha, env) != 0:
            status = 1
    return status


def post_commit(root: Path) -> int:
    _run(["uv", "run", "scripts/process/gate_runner.py", "--warn"], root)
    return 0


def main() -> int:
    if len(sys.argv) != 2 or sys.argv[1] not in {"pre-commit", "pre-push", "post-commit"}:
        print("usage: run_hook.py <pre-commit|pre-push|post-commit>", file=sys.stderr)
        return 2
    try:
        root = _root()
    except RuntimeError as exc:
        print(f"hook: error: {exc}", file=sys.stderr)
        return 1
    return {
        "pre-commit": pre_commit,
        "pre-push": pre_push,
        "post-commit": post_commit,
    }[sys.argv[1]](root)


if __name__ == "__main__":
    raise SystemExit(main())
