#!/usr/bin/env python3
"""arch-onboarding gate: verify the machine-checkable claims in the fenced
```arch block of ARCHITECTURE.md against the real code.

Existence/location is hard-guaranteed; layering conformance is best-effort
(a present arch-linter, else a manual-review checklist). Language-agnostic.
Only an exact ```arch fence is read — an inert ```arch-example seed is ignored."""
from __future__ import annotations

import re
import shutil
import subprocess
import sys
from pathlib import Path

import yaml

# the decision-records gate (core, always rendered) owns ADR file identity —
# import, don't copy (one owner per behavior)
sys.path.insert(0, str(Path(__file__).resolve().parent))  # sibling import
from check_decisions import ADR_DIR, adr_exists as _adr_exists  # noqa: E402


def extract_block(md: str) -> tuple[str | None, bool]:
    """(block, unclosed). block is the ```arch fence content when properly
    closed; unclosed=True when a fence opened but never closed — that must be
    a hard failure, or a missing closing fence silently disables the gate."""
    inside, out = False, []
    for line in md.splitlines():
        s = line.strip()
        if not inside:
            if s == "```arch":
                inside = True
            continue
        if s == "```":
            return "\n".join(out), False
        out.append(line)
    return None, inside


def _has_importlinter(root: Path) -> bool:
    if (root / ".importlinter").is_file():
        return True
    for cfg_name, marker in (("setup.cfg", "[importlinter]"), ("pyproject.toml", "[tool.importlinter]")):
        cfg = root / cfg_name
        if cfg.is_file() and marker in cfg.read_text(encoding="utf-8"):
            return True
    return False


def _has_depcruise(root: Path) -> bool:
    return any(
        (root / f).is_file()
        for f in (
            ".dependency-cruiser.js",
            ".dependency-cruiser.cjs",
            ".dependency-cruiser.mjs",
            ".dependency-cruiser.json",
            ".dependency-cruiser.yaml",
            ".dependency-cruiser.yml",
        )
    )


def _conformance(root: Path, rules: list, code_roots: list) -> tuple[list[str], list[str]]:
    hard: list[str] = []
    soft: list[str] = []
    ran = False
    configured_missing = False
    linters = []
    if _has_importlinter(root):
        # import-linter reads its contracts and source package from its own config.
        linters.append(("lint-imports", ["lint-imports"]))
    if _has_depcruise(root):
        # dependency-cruiser needs the source paths to scan as positional args;
        # without them it cannot analyze anything. Take them from code_roots.
        if code_roots:
            linters.append(("depcruise", ["depcruise", "--validate", *(str(c) for c in code_roots)]))
        else:
            soft.append("arch-linter 'depcruise' configured but manifest has no code_roots to scan")
            configured_missing = True
    for label, cmd in linters:
        binary = shutil.which(cmd[0])
        if binary is None:
            soft.append(f"arch-linter '{label}' configured but not installed — conformance unverified")
            configured_missing = True
            continue
        ran = True
        if subprocess.run([binary, *cmd[1:]], cwd=root).returncode != 0:
            hard.append(f"arch-linter '{label}' reported layering violations")
    if not ran and not hard and not configured_missing:
        for rule in rules:
            soft.append(f"conformance not machine-verified (no arch-linter): review 'forbid {rule.get('forbid')}' manually")
    return hard, soft


def check(root: Path) -> tuple[list[str], list[str]]:
    arch = root / "ARCHITECTURE.md"
    if not arch.is_file():
        return [], ["architecture not onboarded yet (no ARCHITECTURE.md)"]
    try:
        md = arch.read_text(encoding="utf-8")
    except UnicodeDecodeError as exc:
        return [f"ARCHITECTURE.md is not valid UTF-8: {exc}"], []
    block, unclosed = extract_block(md)
    if unclosed:
        return ["unclosed ```arch fence in ARCHITECTURE.md — add the closing ```"], []
    if block is None:
        return [], ["architecture not onboarded yet (no ```arch block)"]

    try:
        data = yaml.safe_load(block)
    except yaml.YAMLError as exc:
        return [f"arch block is not valid YAML: {exc}"], []
    if data is None:
        data = {}
    if not isinstance(data, dict):
        return [f"arch block must be a YAML mapping, got {type(data).__name__}"], []

    hard: list[str] = []
    code_roots = data.get("code_roots", []) or []
    # a YAML scalar (`code_roots: src`) must not be iterated character-wise
    # into "s / r / c" and fed to the linter as paths (audit false-red)
    if not isinstance(code_roots, list):
        hard.append(f"'code_roots' must be a list, got {type(code_roots).__name__}")
        code_roots = []

    for r in code_roots:
        if not (root / str(r)).exists():
            hard.append(f"code_root missing: {r}")

    layers = data.get("layers", {}) or {}
    if not isinstance(layers, dict):
        hard.append(f"'layers' must be a mapping, got {type(layers).__name__}")
        layers = {}
    for name, spec in layers.items():
        path = spec.get("path") if isinstance(spec, dict) else None
        if not path:
            hard.append(f"layer '{name}' has no path")
        elif not (root / str(path)).exists():
            hard.append(f"layer '{name}' path missing: {path}")

    for iface in data.get("interfaces", []) or []:
        if not isinstance(iface, dict):
            hard.append(f"interface entry is not a mapping: {iface!r}")
            continue
        name, path = iface.get("name"), iface.get("path")
        if not name:
            hard.append(f"interface entry missing 'name' (path: {path})")
            continue
        target = root / str(path) if path else None
        if not target or not target.is_file():
            hard.append(f"interface '{name}' file missing: {path}")
            continue
        try:
            source = target.read_text(encoding="utf-8")
        except UnicodeDecodeError as exc:
            hard.append(f"interface '{name}' file not valid UTF-8: {path} ({exc})")
            continue
        if not re.search(rf"\b{re.escape(str(name))}\b", source):
            hard.append(f"interface symbol '{name}' not found in {path}")

    rules = data.get("rules", []) or []
    for rule in rules:
        if not isinstance(rule, dict):
            hard.append(f"rule entry is not a mapping: {rule!r}")
            continue
        forbid = rule.get("forbid", "")
        m = re.match(r"\s*([\w-]+)\s*->\s*([\w-]+)\s*$", str(forbid))
        if not m:
            hard.append(f"malformed rule forbid: {forbid!r}")
        else:
            for layer in (m.group(1), m.group(2)):
                if layer not in layers:
                    hard.append(f"rule references unknown layer '{layer}' in {forbid!r}")
        adr = rule.get("adr")
        if adr and not _adr_exists(root, adr):
            hard.append(f"rule adr link '{adr}' has no file under {ADR_DIR}/")

    valid_rules = [r for r in rules if isinstance(r, dict)]
    hard_c, soft = _conformance(root, valid_rules, code_roots) if valid_rules else ([], [])
    return hard + hard_c, soft


def main() -> int:
    root = Path(sys.argv[1] if len(sys.argv) > 1 else ".").resolve()
    hard, soft = check(root)
    for note in soft:
        print(f"arch-gate: note: {note}")
    if hard:
        print("arch-gate: FAILED:")
        for h in hard:
            print(f"  - {h}")
        return 1
    print("arch-gate: OK")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
