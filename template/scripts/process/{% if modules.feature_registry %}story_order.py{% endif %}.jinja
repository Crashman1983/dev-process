#!/usr/bin/env python3
"""story_order: a read-only ready-to-start view over the feature-registry.

Never a gate, never in CI — it reports, it does not fail. The registry gate is
what *enforces* that `blocked_by` refs resolve and are acyclic; this tool just
answers "what is safe to start now, and in what order?" from the same data.

Usage: python scripts/process/story_order.py [ROOT]

Stdlib only."""
from __future__ import annotations

import json
import sys
from pathlib import Path

REGISTRY_DIR = "docs/process/feature-registry"


def _load(root: Path) -> dict:
    reg = root / REGISTRY_DIR
    stories: dict = {}
    if not reg.is_dir():
        return stories
    for p in sorted(reg.glob("*.json")):
        if p.name.endswith(".example.json"):
            continue
        try:
            d = json.loads(p.read_text(encoding="utf-8"))
        except (json.JSONDecodeError, UnicodeDecodeError):
            continue
        if not isinstance(d, dict):
            continue
        sid = d.get("id")
        if not isinstance(sid, str) or not sid:
            continue
        deps = [x for x in (d.get("blocked_by") or []) if isinstance(x, str)]
        stories[sid] = {"status": d.get("status"), "deps": deps,
                        "title": d.get("title") or ""}
    return stories


def _is_done(stories: dict, sid: str) -> bool:
    return sid in stories and stories[sid]["status"] == "done"


def report(stories: dict) -> list[str]:
    """The printable lines — separated from I/O so tests can assert on them."""
    if not stories:
        return ["story-order: no stories"]
    pending = {sid: n for sid, n in stories.items() if n["status"] != "done"}

    ready, blocked = [], []
    for sid in sorted(pending):
        unfinished = [d for d in pending[sid]["deps"] if not _is_done(stories, d)]
        (blocked if unfinished else ready).append((sid, unfinished))

    out = ["Ready to start (no unfinished blockers):"]
    out += [f"  {sid}  {stories[sid]['title']}" for sid, _ in ready] or ["  (none)"]
    out.append("")
    out.append("Blocked:")
    out += [f"  {sid}  waits on: {', '.join(unf)}" for sid, unf in blocked] or ["  (none)"]

    # topological order of the pending subgraph (Kahn); leftover ⇒ a cycle
    pend_deps = {sid: {d for d in pending[sid]["deps"] if d in pending} for sid in pending}
    dependents: dict = {sid: [] for sid in pending}
    for sid, ds in pend_deps.items():
        for d in ds:
            dependents[d].append(sid)
    indeg = {sid: len(pend_deps[sid]) for sid in pending}
    queue = sorted(sid for sid in pending if indeg[sid] == 0)
    order: list[str] = []
    while queue:
        sid = queue.pop(0)
        order.append(sid)
        for dep in sorted(dependents[sid]):
            indeg[dep] -= 1
            if indeg[dep] == 0:
                queue.append(dep)
        queue.sort()
    out.append("")
    out.append("Suggested order:")
    out += [f"  {i + 1}. {sid}" for i, sid in enumerate(order)] or ["  (none)"]
    leftover = [sid for sid in pending if sid not in order]
    if leftover:
        out.append(f"  ! cycle among: {', '.join(sorted(leftover))} "
                   f"(the registry gate fails on this — fix it there)")
    return out


def main() -> int:
    root = Path(sys.argv[1] if len(sys.argv) > 1 else ".").resolve()
    for line in report(_load(root)):
        print(line)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
