#!/usr/bin/env python3
# /// script
# requires-python = ">=3.11"
# ///
"""Create a temporary issue body from a rendered GitHub issue template."""
from __future__ import annotations

import re
import sys
import tempfile
from pathlib import Path

SAFE_KIND = re.compile(r"^[A-Za-z0-9][A-Za-z0-9_-]*$")


def main() -> int:
    args = sys.argv[1:]
    if len(args) != 1 or not SAFE_KIND.fullmatch(args[0]):
        print("new-issue: error: provide one safe template name", file=sys.stderr)
        return 2
    root = Path(__file__).resolve().parents[2]
    source = root / ".github" / "ISSUE_TEMPLATE" / f"{args[0]}.md"
    if not source.is_file():
        print(f"new-issue: error: no such template: {source.relative_to(root)}", file=sys.stderr)
        return 2
    lines = source.read_text(encoding="utf-8").splitlines(keepends=True)
    body = "".join(lines)
    if lines and lines[0].strip() == "---":
        for index, line in enumerate(lines[1:], start=1):
            if line.strip() == "---":
                body = "".join(lines[index + 1 :])
                break
    with tempfile.NamedTemporaryFile(
        mode="w", encoding="utf-8", suffix=".md", prefix="issue-body-", delete=False
    ) as output:
        output.write(body)
        path = output.name
    print(path)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
