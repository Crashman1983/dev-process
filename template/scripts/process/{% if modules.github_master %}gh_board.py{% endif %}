#!/usr/bin/env python3
"""gh_board: pull a GitHub Project board's Status field into the snapshot's
`board_status` slot.

Like gh_sync.py, this is the network layer — best-effort, `gh`-dependent, never
a gate. It fills `board_status`; the github-master gate then checks, offline,
that the column is consistent with the story status and issue state. The tested,
hermetic contract is the gate, not this tool. This tool only READS the board —
moving cards stays a manual (or project-automation) act; the gate flags the
divergence either way.

Usage:
  python scripts/process/gh_board.py <project-number> [--owner OWNER]

Stdlib + `gh`.
"""
from __future__ import annotations

import json
import shutil
import subprocess
import sys
from pathlib import Path

SNAPSHOT = ".process-work/github-snapshot.json"


def _run_gh(gh: str, args: list[str]) -> dict | list | None:
    try:
        r = subprocess.run([gh, *args], capture_output=True, text=True, timeout=60)
    except (subprocess.TimeoutExpired, OSError) as exc:
        print(f"gh_board: gh failed: {exc}", file=sys.stderr)
        return None
    if r.returncode != 0:
        print(f"gh_board: gh failed: {r.stderr.strip()}", file=sys.stderr)
        return None
    return json.loads(r.stdout) if r.stdout.strip() else None


def main() -> int:
    root = Path(".").resolve()
    args = sys.argv[1:]
    owner = None
    if "--owner" in args:
        i = args.index("--owner")
        owner = args[i + 1] if i + 1 < len(args) else None
        args = args[:i] + args[i + 2:]
    # exactly one positional, no unknown flags — a stale `--push` (removed) or a
    # typo must error loudly, not ride into `gh` as the project number
    if len(args) != 1 or args[0].startswith("-"):
        print("gh_board: usage: gh_board.py <project-number> [--owner OWNER]",
              file=sys.stderr)
        return 1
    project = args[0]
    gh = shutil.which("gh")
    if not gh:
        print("gh_board: `gh` not on PATH", file=sys.stderr)
        return 1

    snap_path = root / SNAPSHOT
    if not snap_path.is_file():
        print(f"gh_board: no {SNAPSHOT} — run gh_sync.py first", file=sys.stderr)
        return 1
    snapshot = json.loads(snap_path.read_text(encoding="utf-8"))
    by_number = {e.get("number"): e for e in snapshot.get("issues", [])
                 if e.get("number") is not None}

    cmd = ["project", "item-list", project, "--format", "json", "--limit", "500"]
    if owner:
        cmd += ["--owner", owner]
    data = _run_gh(gh, cmd)
    if data is None:
        return 1

    filled = 0
    for item in (data.get("items", []) if isinstance(data, dict) else []):
        content = item.get("content") or {}
        num = content.get("number")
        if num is None:  # a draft / numberless card is not an issue
            continue
        entry = by_number.get(num)
        if entry is None:
            continue
        entry["board_status"] = item.get("status")  # the board's Status field
        filled += 1

    snap_path.write_text(json.dumps(snapshot, indent=2) + "\n", encoding="utf-8")
    print(f"gh_board: filled board_status for {filled} issue(s) in {SNAPSHOT} — commit it")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
