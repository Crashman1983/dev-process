#!/usr/bin/env python3
"""gh_board: pull a GitHub Project board's Status field into the snapshot's
`board_status` slot (and, with --push, move a card to the column its story
status implies).

Like gh_sync.py, this is the network layer — best-effort, `gh`-dependent, never
a gate. It fills `board_status`; the github-master gate then checks, offline,
that the column is consistent with the story status and issue state. The tested,
hermetic contract is the gate, not this tool.

Usage:
  python scripts/process/gh_board.py <project-number> [--owner OWNER] [--push]

--push moves a card whose column disagrees with its story status to the column
that status implies (a GitHub write; needs the `project` scope). Off by default.

Stdlib + `gh`.
"""
from __future__ import annotations

import json
import re
import shutil
import subprocess
import sys
from pathlib import Path

REGISTRY_DIR = "docs/process/feature-registry"
SNAPSHOT = ".process-work/github-snapshot.json"
# story status -> the board column to move a card to under --push
STATUS_COLUMN = {"proposed": "Backlog", "in-progress": "In-progress", "done": "Done"}


def _run_gh(gh: str, args: list[str]) -> dict | list | None:
    try:
        r = subprocess.run([gh, *args], capture_output=True, text=True, timeout=60)
    except (subprocess.TimeoutExpired, OSError) as exc:
        print(f"gh_board: gh failed: {exc}", file=sys.stderr)
        return None
    if r.returncode != 0:
        print(f"gh_board: gh failed: {r.stderr.strip()}", file=sys.stderr)
        return None
    return json.loads(r.stdout) if r.stdout.strip() else None


def _issue_to_story(root: Path) -> dict:
    reg = root / REGISTRY_DIR
    out: dict = {}
    if not reg.is_dir():
        return out
    for p in sorted(reg.glob("*.json")):
        if p.name.endswith(".example.json"):
            continue
        try:
            d = json.loads(p.read_text(encoding="utf-8"))
        except (json.JSONDecodeError, UnicodeDecodeError):
            continue
        issue, sid = d.get("issue"), d.get("id")
        m = re.search(r"(\d+)$", str(issue)) if issue else None
        if m and isinstance(sid, str):
            out[int(m.group(1))] = sid
    return out


def main() -> int:
    root = Path(".").resolve()
    gh = shutil.which("gh")
    if not gh:
        print("gh_board: `gh` not on PATH", file=sys.stderr)
        return 1
    args = sys.argv[1:]
    push = "--push" in args
    args = [a for a in args if a != "--push"]
    owner = None
    if "--owner" in args:
        i = args.index("--owner")
        owner = args[i + 1] if i + 1 < len(args) else None
        args = args[:i] + args[i + 2:]
    if not args:
        print("gh_board: usage: gh_board.py <project-number> [--owner OWNER] [--push]",
              file=sys.stderr)
        return 1
    project = args[0]

    snap_path = root / SNAPSHOT
    if not snap_path.is_file():
        print(f"gh_board: no {SNAPSHOT} — run gh_sync.py first", file=sys.stderr)
        return 1
    snapshot = json.loads(snap_path.read_text(encoding="utf-8"))
    by_number = {e.get("number"): e for e in snapshot.get("issues", [])}
    mapping = _issue_to_story(root)

    cmd = ["project", "item-list", project, "--format", "json", "--limit", "500"]
    if owner:
        cmd += ["--owner", owner]
    data = _run_gh(gh, cmd)
    if data is None:
        return 1

    filled = 0
    for item in (data.get("items", []) if isinstance(data, dict) else []):
        content = item.get("content") or {}
        num = content.get("number")
        entry = by_number.get(num)
        if entry is None:
            continue
        entry["board_status"] = item.get("status")  # the board's Status field
        filled += 1

    snap_path.write_text(json.dumps(snapshot, indent=2) + "\n", encoding="utf-8")
    print(f"gh_board: filled board_status for {filled} issue(s) in {SNAPSHOT} — commit it")

    if push:
        # best-effort: move cards whose column disagrees with the story status.
        # `gh project item-edit` needs the item id + the Status field/option ids;
        # wire your project's ids here — left as an explicit extension point so
        # the tool never guesses a destructive write.
        print("gh_board: --push is an extension point — see the module doc; "
              "no cards were moved", file=sys.stderr)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
