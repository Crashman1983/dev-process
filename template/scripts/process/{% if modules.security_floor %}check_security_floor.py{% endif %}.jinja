#!/usr/bin/env python3
"""security-floor gate: the grep-able subset of a project's security invariants,
enforced as a blocking gate. The project declares forbidden regex patterns in
docs/process/security-floor.json; the gate scans git-tracked files and fails CI
(exit 1) on a match. A present-but-broken config also fails. Enumeration needs
git; if git is unavailable the scan is skipped with an advisory note, never faked
as a pass. Bypass: SKIP_SECURITY_FLOOR=1. Python stdlib only."""
from __future__ import annotations

import fnmatch
import json
import os
import re
import subprocess
import sys
import time
from pathlib import Path

CONFIG = "docs/process/security-floor.json"

# the decision-records gate (core, always rendered) owns ADR file identity —
# import, don't copy (one owner per behavior)
sys.path.insert(0, str(Path(__file__).resolve().parent))  # sibling import
from check_decisions import ADR_DIR, adr_exists as _adr_exists  # noqa: E402
# never scan the policy file itself (it holds the patterns), the shipped seed the
# doc says to copy, or the gate script — a rule must not flag its own tooling.
SELF_EXCLUDE = {
    CONFIG,
    "docs/process/security-floor.example.json",
    "scripts/process/check_security_floor.py",
}


# kept byte-identical with check_sbom.py's twin (independent render units —
# neither module may import the other); tests/test_one_owner.py pins this
def _tracked_files(root: Path) -> list[str] | None:
    try:
        r = subprocess.run(["git", "-C", str(root), "ls-files", "-z"],
                           capture_output=True, timeout=30)
    except (OSError, subprocess.TimeoutExpired):
        return None
    if r.returncode != 0:
        return None
    return [p for p in r.stdout.decode("utf-8", "replace").split("\0") if p]


def _matches_any(rel: str, globs: list[str]) -> bool:
    base = rel.rsplit("/", 1)[-1]
    return any(fnmatch.fnmatch(rel, g) or fnmatch.fnmatch(base, g) for g in globs)


def _load_config(root: Path) -> tuple[dict | None, list[str]]:
    p = root / CONFIG
    if not p.is_file():
        return None, []
    try:
        data = json.loads(p.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        return None, [f"{CONFIG}: invalid JSON: {exc}"]
    except UnicodeDecodeError as exc:
        return None, [f"{CONFIG}: not valid UTF-8: {exc}"]
    except OSError as exc:
        return None, [f"{CONFIG}: could not read: {exc}"]
    if not isinstance(data, dict):
        return None, [f"{CONFIG}: must be a JSON object"]
    return data, []


def _validate(cfg: dict) -> tuple[list[dict], list[str], list[str]]:
    hard: list[str] = []
    rules_raw = cfg.get("rules")
    if not isinstance(rules_raw, list):
        return [], [], [f"{CONFIG}: 'rules' must be a list"]
    # a present-but-malformed 'exclude' is a broken policy (silently dropping it
    # would discard the author's intent), so it is hard — absent stays the default.
    raw_exclude = cfg.get("exclude")
    exclude: list[str] = []
    if raw_exclude is not None:
        if isinstance(raw_exclude, list) and all(isinstance(g, str) for g in raw_exclude):
            exclude = raw_exclude
        else:
            hard.append(f"{CONFIG}: 'exclude' must be a list of glob strings")
    compiled: list[dict] = []
    for i, rule in enumerate(rules_raw):
        if not isinstance(rule, dict):
            hard.append(f"{CONFIG}: rule #{i} must be an object")
            continue
        rid = rule.get("id")
        pattern = rule.get("pattern")
        message = rule.get("message")
        applies = rule.get("applies_to")
        # label the rule by id when it is usable, else by index — never "rule None".
        label = rid if isinstance(rid, str) and rid.strip() else f"#{i}"
        if not isinstance(rid, str) or not rid.strip():
            hard.append(f"{CONFIG}: rule #{i} 'id' must be a non-empty string")
        if not isinstance(message, str) or not message.strip():
            hard.append(f"{CONFIG}: rule {label!r} 'message' must be a non-empty string")
        # an empty applies_to passes an is-list check but scans zero files — the
        # rule would look active while checking nothing, so it is hard.
        if applies is not None and not (
            isinstance(applies, list) and applies and all(isinstance(g, str) for g in applies)
        ):
            hard.append(
                f"{CONFIG}: rule {label!r} 'applies_to' must be a non-empty list of "
                "glob strings (omit it to scan all files)"
            )
            applies = None
        # optional adr link: a floor rule (e.g. an architecture boundary) may name
        # the decision record it enforces — the link must then resolve.
        adr = rule.get("adr")
        if adr is not None and not (isinstance(adr, str) and re.search(r"\d", adr)):
            hard.append(f"{CONFIG}: rule {label!r} 'adr' must reference a decision "
                        "record like 'ADR-0002' (or be omitted)")
            adr = None
        if not isinstance(pattern, str) or not pattern:
            hard.append(f"{CONFIG}: rule {label!r} 'pattern' must be a non-empty string")
            continue
        try:
            regex = re.compile(pattern)
        except re.error as exc:
            hard.append(f"{CONFIG}: rule {label!r} pattern is not a valid regex: {exc}")
            continue
        compiled.append({"id": rid, "regex": regex, "applies_to": applies,
                         "message": message, "adr": adr})
    return compiled, exclude, hard


def check(root: Path) -> tuple[list[str], list[str]]:
    cfg, errs = _load_config(root)
    if errs:
        return errs, []
    if cfg is None:
        return [], [f"no security-floor config yet ({CONFIG} absent)"]
    rules, exclude, hard = _validate(cfg)
    # a rule claiming a decision record that does not exist is a lie to the next
    # reader — config integrity, checked before any scanning. Walk the RAW rules,
    # not the compiled ones: an invalid pattern must not hide a dangling link.
    for i, rule in enumerate(cfg.get("rules") or []):
        if not isinstance(rule, dict):
            continue
        adr = rule.get("adr")
        if isinstance(adr, str) and re.search(r"\d", adr) and not _adr_exists(root, adr):
            label = rule.get("id") if isinstance(rule.get("id"), str) else f"#{i}"
            hard.append(f"{CONFIG}: rule {label!r} links {adr!r} but no such "
                        f"decision record exists under {ADR_DIR}/")
    if hard:
        return hard, []
    if not rules:
        return [], ["security-floor config has no rules"]
    files = _tracked_files(root)
    if files is None:
        return [], ["could not list tracked files (git unavailable); scan skipped"]
    if not files:
        return [], ["0 tracked files scanned — nothing committed/staged yet, floor not exercised"]

    findings: list[str] = []
    skipped: list[str] = []
    scanned = 0
    # a pathological pattern (catastrophic backtracking) must not wedge CI:
    # each rule gets a wall-clock budget, checked between lines; exceeding it
    # is a hard, named failure — rewrite the pattern. Overridable for tests.
    budget_s = float(os.environ.get("SECURITY_FLOOR_RULE_BUDGET_S", "10"))
    spent: dict[str, float] = {}
    blown: set[str] = set()
    for rel in files:
        if rel in SELF_EXCLUDE:
            continue
        if exclude and _matches_any(rel, exclude):
            continue
        applicable = [r for r in rules if r["applies_to"] is None or _matches_any(rel, r["applies_to"])]
        if not applicable:
            continue
        try:
            text = (root / rel).read_text(encoding="utf-8")
        except (UnicodeDecodeError, OSError):
            # binary/unreadable — cannot grep it. A grep gate silently passing an
            # unscannable file is false confidence on a security check, so the
            # skip is disclosed, not swallowed (it stays advisory: this floor is
            # the grep-able subset, not a full secret scanner).
            skipped.append(rel)
            continue
        scanned += 1
        for lineno, line in enumerate(text.splitlines(), 1):
            for r in applicable:
                if r["id"] in blown:
                    continue
                t0 = time.monotonic()
                match = r["regex"].search(line)
                spent[r["id"]] = spent.get(r["id"], 0.0) + (time.monotonic() - t0)
                if match:
                    findings.append(f"{rel}:{lineno}: {r['message']} [{r['id']}]")
                elif spent[r["id"]] > budget_s:
                    blown.add(r["id"])
                    findings.append(f"{CONFIG}: rule {r['id']!r} exceeded its "
                                    f"{budget_s:g}s scan budget — likely "
                                    f"catastrophic backtracking; rewrite the pattern")
    soft: list[str] = []
    if scanned == 0:
        # an exclude/applies_to combination that leaves nothing in scope is the
        # same silent neuter as an empty tree — disclose it, never a bare green
        soft.append("0 files in scope after exclude/applies_to — floor not exercised")
    if skipped:
        shown = ", ".join(skipped[:5]) + (" …" if len(skipped) > 5 else "")
        soft.append(f"{len(skipped)} file(s) not scanned (binary/unreadable), "
                    f"NOT covered by the floor: {shown}")
    return findings, soft


def main() -> int:
    if os.environ.get("SKIP_SECURITY_FLOOR") == "1":
        print("security-floor: skipped (SKIP_SECURITY_FLOOR=1)")
        return 0
    root = Path(sys.argv[1] if len(sys.argv) > 1 else ".").resolve()
    hard, soft = check(root)
    for note in soft:
        print(f"security-floor: note: {note}")
    if hard:
        print("security-floor: FAILED:")
        for h in hard:
            print(f"  - {h}")
        print("  → fix, or bypass with SKIP_SECURITY_FLOOR=1 (and say why in the commit).")
        return 1
    print("security-floor: OK")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
