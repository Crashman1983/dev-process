#!/usr/bin/env bash
# Wire `process-gates` as a REQUIRED status check on the default branch — the
# single step that turns "the gate runs" into "the gate blocks" (see
# docs/process/start-here.md, Definition of ready). CI cannot set this itself.
#
# Idempotent and non-destructive — an existing protection rule is NEVER
# rewritten by this script:
#   - protection exists, status checks enabled -> only ADD the process-gates
#     context (nothing else is touched);
#   - protection exists, status checks NOT enabled -> refuse with instructions
#     (enabling them means rewriting the rule — that stays a deliberate human
#     step in the UI);
#   - no protection at all -> create a minimal rule that requires only the
#     process-gates check (no forced PR reviews — solo-friendly; tighten in the
#     GitHub UI as the team grows).
#
# Needs: gh CLI authenticated with admin rights on the repo. Honest limits:
# branch protection on PRIVATE repos requires a paid GitHub plan (public repos:
# free) — a 403/upgrade error means plan, not script. Manual path: Settings ->
# Branches -> protect the default branch -> require the `process-gates` check.
set -euo pipefail

CONTEXT="process-gates"

command -v gh >/dev/null || { echo "setup-branch-protection: gh CLI not found — install https://cli.github.com/ and run 'gh auth login'." >&2; exit 1; }

repo="$(gh repo view --json nameWithOwner --jq .nameWithOwner)" \
  || { echo "setup-branch-protection: not inside a GitHub repo gh can see (run from the repo, gh authenticated)." >&2; exit 1; }
branch="$(gh repo view --json defaultBranchRef --jq .defaultBranchRef.name)" \
  || { echo "setup-branch-protection: could not resolve the default branch (gh authenticated? repo pushed?)." >&2; exit 1; }
echo "repo: $repo  default branch: $branch"

api="repos/$repo/branches/$branch/protection"
err_file="$(mktemp "${TMPDIR:-/tmp}/sbp.XXXXXX")"
trap 'rm -f "$err_file"' EXIT

# Probe the WHOLE protection rule first. GET .../required_status_checks alone is
# ambiguous: it 404s both when the branch is unprotected AND when a rule exists
# without status checks (e.g. required-PR-reviews only) — acting on that
# ambiguity could overwrite a real rule. Only an explicit "Branch not protected"
# may take the create path; any other failure stops, untouched.
prot_err=""
if prot="$(gh api "$api" 2>"$err_file")"; then
  # --- a protection rule exists: never rewrite it ---
  if printf '%s' "$prot" | grep -q '"required_status_checks"'; then
    if printf '%s' "$prot" | grep -q "\"$CONTEXT\""; then
      echo "✓ '$CONTEXT' is already a required status check on $branch"
      exit 0
    fi
    gh api -X POST "$api/required_status_checks/contexts" \
      -f "contexts[]=$CONTEXT" >/dev/null
    echo "✓ added '$CONTEXT' to the existing required status checks on $branch"
  else
    echo "setup-branch-protection: $branch already has a protection rule, but" >&2
    echo "  required status checks are not enabled on it. Enabling them means" >&2
    echo "  rewriting the existing rule — do that deliberately in the UI:" >&2
    echo "  Settings -> Branches -> edit the rule for '$branch' -> enable" >&2
    echo "  'Require status checks to pass' -> add '$CONTEXT'." >&2
    echo "  This script never rewrites an existing rule." >&2
    exit 1
  fi
else
  prot_err="$(cat "$err_file" 2>/dev/null || true)"
  if ! printf '%s' "$prot_err" | grep -qi "Branch not protected"; then
    echo "setup-branch-protection: could not read the protection state — not touching anything." >&2
    echo "  gh said: ${prot_err:-<no error output>}" >&2
    echo "  Common causes: missing admin rights, network, or a private repo on" >&2
    echo "  the free plan (branch protection needs a paid plan there)." >&2
    exit 1
  fi
  # --- genuinely unprotected: create the minimal rule ---
  # strict=false: a branch need not be up to date with main, only green.
  body="$(printf '{"required_status_checks":{"strict":false,"contexts":["%s"]},"enforce_admins":false,"required_pull_request_reviews":null,"restrictions":null}' "$CONTEXT")"
  if ! printf '%s' "$body" | gh api -X PUT "$api" --input - >/dev/null; then
    echo "setup-branch-protection: could not create protection." >&2
    echo "  Common causes: missing admin rights, or a private repo on the free" >&2
    echo "  plan (branch protection needs a paid plan there; public repos are" >&2
    echo "  free). Manual path: Settings -> Branches -> protect '$branch' ->" >&2
    echo "  require the '$CONTEXT' status check." >&2
    exit 1
  fi
  echo "✓ created branch protection on $branch requiring '$CONTEXT' (minimal rule — no forced PR reviews; tighten in the UI as the team grows)"
fi
