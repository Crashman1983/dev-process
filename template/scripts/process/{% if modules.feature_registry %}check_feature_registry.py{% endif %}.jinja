#!/usr/bin/env python3
"""feature-registry gate: validate the story files under
docs/process/feature-registry/ — the requirements / acceptance / test
traceability SSOT.

Structure and reference existence are hard-guaranteed (CI exit 1). Whether a
test *semantically* proves its acceptance criterion is not mechanically
decidable — a missing test mapping is flagged best-effort, never faked as
verified. Language-agnostic; stdlib only (plus the shared adr glob)."""
from __future__ import annotations

import json
import re
import sys
from pathlib import Path

REGISTRY_DIR = "docs/process/feature-registry"
ADR_DIR = "docs/process/adr"
STATUSES = {"proposed", "in-progress", "done", "deprecated"}
ID_RE = re.compile(r"^STORY-\d{4}$")


def _story_files(root: Path) -> list[Path]:
    reg = root / REGISTRY_DIR
    if not reg.is_dir():
        return []
    return sorted(p for p in reg.glob("*.json") if not p.name.endswith(".example.json"))


def _adr_exists(root: Path, adr: object) -> bool:
    m = re.search(r"\d+", str(adr))
    if not m:
        return False
    return bool(list((root / ADR_DIR).glob(f"adr-{int(m.group()):04d}-*.md")))


def _check_story(root: Path, path: Path, seen_ids: dict,
                 graph: dict) -> tuple[list[str], list[str]]:
    hard: list[str] = []
    soft: list[str] = []
    rel = path.relative_to(root)
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except (json.JSONDecodeError, UnicodeDecodeError) as exc:
        return [f"{rel}: invalid JSON: {exc}"], []
    if not isinstance(data, dict):
        return [f"{rel}: story must be a JSON object, got {type(data).__name__}"], []

    sid = data.get("id")
    if not isinstance(sid, str) or not sid:
        hard.append(f"{rel}: missing or non-string 'id'")
    elif not ID_RE.match(sid):
        hard.append(f"{rel}: 'id' must match STORY-NNNN, got {sid!r}")
    elif sid in seen_ids:
        hard.append(f"{rel}: duplicate id {sid!r} (also in {seen_ids[sid]})")
    else:
        seen_ids[sid] = str(rel)

    if not data.get("title"):
        hard.append(f"{rel}: missing 'title'")
    if not data.get("story"):
        hard.append(f"{rel}: missing 'story'")

    if data.get("status") not in STATUSES:
        hard.append(f"{rel}: 'status' must be one of {sorted(STATUSES)}, got {data.get('status')!r}")

    acceptance = data.get("acceptance")
    n_acc = 0
    if not isinstance(acceptance, list) or not acceptance:
        hard.append(f"{rel}: 'acceptance' must be a non-empty list")
    else:
        n_acc = len(acceptance)
        for i, ac in enumerate(acceptance):
            text = ac.get("text") if isinstance(ac, dict) else None
            if not isinstance(text, str) or not text.strip():
                hard.append(f"{rel}: acceptance[{i}] 'text' must be a non-empty string")

    tests = data.get("tests") or []
    if not isinstance(tests, list):
        hard.append(f"{rel}: 'tests' must be a list")
        tests = []
    n_tests = 0
    for t in tests:
        file_part = str(t).split("::", 1)[0]  # strip a pytest ::node selector
        if not (root / file_part).is_file():
            hard.append(f"{rel}: test path does not exist: {t}")
        else:
            n_tests += 1

    # the 'done requires a test' rule is parent-aware — an epic is covered by its
    # children's tests — so it runs in the cross-story pass, not here.

    adr = data.get("adr")
    if adr and not _adr_exists(root, adr):
        hard.append(f"{rel}: adr link {adr!r} has no file under {ADR_DIR}/")

    if data.get("status") in ("in-progress", "done") and n_acc > n_tests:
        soft.append(f"{rel}: {n_acc} acceptance criteria but {n_tests} mapped test(s) — coverage unverified")

    # blocked_by: a list of STORY-NNNN ids this story depends on. Format is
    # validated here; dangling refs and cycles need the whole set (in check()).
    blocked = data.get("blocked_by", [])
    deps: list[str] = []
    if blocked in (None, []):
        pass
    elif not isinstance(blocked, list):
        hard.append(f"{rel}: 'blocked_by' must be a list of STORY-NNNN ids")
    else:
        for b in blocked:
            if not isinstance(b, str) or not ID_RE.match(b):
                hard.append(f"{rel}: blocked_by entry {b!r} must match STORY-NNNN")
            else:
                deps.append(b)
    # parent: a single STORY-NNNN this story decomposes (tree, not sequencing).
    parent = data.get("parent")
    parent_id: str | None = None
    if parent in (None, ""):
        pass
    elif not isinstance(parent, str) or not ID_RE.match(parent):
        hard.append(f"{rel}: 'parent' must be a STORY-NNNN id, got {parent!r}")
    else:
        parent_id = parent

    if isinstance(sid, str) and ID_RE.match(sid):
        graph[sid] = {"deps": deps, "status": data.get("status"), "rel": str(rel),
                      "parent": parent_id, "has_test": bool(tests),
                      "title": data.get("title"), "story": data.get("story")}

    return hard, soft


def _cycles(adj: dict, label: str) -> list[str]:
    """`label: a -> b -> a` messages for every cycle in the adjacency map
    (node -> [successors]). One owner for cycle detection — reused by both the
    blocked_by graph and the parent tree. Self-edges are skipped (reported
    separately); cycles are deduped by node-set."""
    WHITE, GRAY, BLACK = 0, 1, 2
    color = dict.fromkeys(adj, WHITE)
    stack: list[str] = []
    seen: set = set()
    out: list[str] = []

    def dfs(u: str) -> None:
        color[u] = GRAY
        stack.append(u)
        for v in adj[u]:
            if v not in color or v == u:
                continue
            if color[v] == GRAY:
                cyc = stack[stack.index(v):] + [v]
                key = frozenset(cyc)
                if key not in seen:
                    seen.add(key)
                    out.append(f"{label}: " + " -> ".join(cyc))
            elif color[v] == WHITE:
                dfs(v)
        stack.pop()
        color[u] = BLACK

    for sid in sorted(adj):
        if color[sid] == WHITE:
            dfs(sid)
    return out


def _dependency_checks(graph: dict) -> tuple[list[str], list[str]]:
    """blocked_by validation: dangling refs, self-references, and cycles are
    hard; a done story with an unfinished blocker is a soft integrity note."""
    hard: list[str] = []
    soft: list[str] = []
    ids = set(graph)
    for sid, node in sorted(graph.items()):
        for d in node["deps"]:
            if d == sid:
                hard.append(f"{node['rel']}: {sid} lists itself in blocked_by")
            elif d not in ids:
                hard.append(f"{node['rel']}: blocked_by {d!r} — no such story")
            elif node["status"] == "done" and graph[d]["status"] != "done":
                soft.append(f"{node['rel']}: {sid} is done but blocker {d} is "
                            f"{graph[d]['status']!r} — dependency order looks off")
    adj = {sid: [d for d in n["deps"] if d in ids] for sid, n in graph.items()}
    hard += _cycles(adj, "dependency cycle")
    return sorted(set(hard)), soft


def _hierarchy_checks(graph: dict) -> tuple[list[str], list[str]]:
    """parent (decomposition) validation, and the parent-aware done-test rule.
    parent is a tree: dangling/self/cycle are hard. An epic (a story that is a
    parent) may be done without its own test — its children cover it; a leaf
    done story without a test stays hard."""
    hard: list[str] = []
    soft: list[str] = []
    ids = set(graph)
    parents = {n["parent"] for n in graph.values() if n["parent"]}
    for sid, n in sorted(graph.items()):
        p = n["parent"]
        if p:
            if p == sid:
                hard.append(f"{n['rel']}: {sid} is its own parent")
            elif p not in ids:
                hard.append(f"{n['rel']}: parent {p!r} — no such story")
            else:
                if graph[p]["status"] == "done" and n["status"] != "done":
                    soft.append(f"{n['rel']}: parent {p} is done but child {sid} is "
                                f"{n['status']!r} — an epic outruns its parts")
                if n["title"] and n["title"] == graph[p]["title"]:
                    soft.append(f"{n['rel']}: {sid} title is identical to parent {p} "
                                f"— a child carries its own delta, not a copy")
                if n["story"] and n["story"] == graph[p]["story"]:
                    soft.append(f"{n['rel']}: {sid} story is identical to parent {p} "
                                f"— a child carries its own delta, not a copy")
        # parent-aware 'done requires a test'
        if n["status"] == "done" and not n["has_test"]:
            if sid in parents:
                soft.append(f"{n['rel']}: {sid} is a done epic without its own test "
                            f"— its children's tests must cover it")
            else:
                hard.append(f"{n['rel']}: status 'done' requires at least one test")

    adj = {sid: ([n["parent"]] if n["parent"] in ids and n["parent"] != sid else [])
           for sid, n in graph.items()}
    hard += _cycles(adj, "parent cycle")
    return sorted(set(hard)), soft


def check(root: Path) -> tuple[list[str], list[str]]:
    files = _story_files(root)
    if not files:
        return [], ["no stories yet (feature-registry empty)"]
    hard: list[str] = []
    soft: list[str] = []
    seen_ids: dict = {}
    graph: dict = {}
    for path in files:
        h, s = _check_story(root, path, seen_ids, graph)
        hard += h
        soft += s
    dh, ds = _dependency_checks(graph)
    hard += dh
    soft += ds
    hh, hs = _hierarchy_checks(graph)
    hard += hh
    soft += hs
    return hard, soft


def main() -> int:
    root = Path(sys.argv[1] if len(sys.argv) > 1 else ".").resolve()
    hard, soft = check(root)
    for note in soft:
        print(f"registry-gate: note: {note}")
    if hard:
        print("registry-gate: FAILED:")
        for h in hard:
            print(f"  - {h}")
        return 1
    print("registry-gate: OK")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
